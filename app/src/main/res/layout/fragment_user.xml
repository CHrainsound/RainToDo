<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".view.fragment.MainFragment">


    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="用户"
        android:textSize="40sp"
        android:paddingHorizontal="18dp"
        android:paddingVertical="15dp"/>


    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="10dp">

                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/gl_user"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    app:layout_constraintGuide_begin="18dp" />


                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_userphoto"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:src="@drawable/ic_user_main"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="@id/gl_user"
                    app:layout_constraintTop_toTopOf="parent"
                    app:shapeAppearanceOverlay="@style/RoundedCornerStyle" />

                <TextView
                    android:id="@+id/tv_username"
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:paddingLeft="10dp"
                    android:text="未知用户"
                    android:textSize="20sp"
                    app:layout_constraintStart_toEndOf="@+id/iv_userphoto"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_write"
                    android:layout_width="200dp"
                    android:layout_height="40dp"
                    android:paddingLeft="11dp"
                    android:text="勇于始，永不释"
                    android:textSize="15sp"
                    app:layout_constraintStart_toEndOf="@+id/iv_userphoto"
                    app:layout_constraintTop_toBottomOf="@+id/tv_username" />

                <ImageView
                    android:id="@+id/iv_switch"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:rotation="270"
                    android:src="@drawable/backicon"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/tv_write"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="切换用户"
                    app:layout_constraintEnd_toEndOf="@+id/iv_switch"
                    app:layout_constraintStart_toStartOf="@+id/iv_switch"
                    app:layout_constraintTop_toBottomOf="@+id/iv_switch" />



            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>